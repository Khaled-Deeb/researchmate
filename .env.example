# For ProxyAPI, put your ProxyAPI key here.
OPENAI_API_KEY=

# Official OpenAI default:
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# ProxyAPI OpenAI-compatible endpoint:
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# OPENAI_BASE_URL=

# LLM settings.
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# fallback = no API, rule-based extraction/search
# openai = OpenAI-compatible API mode
RESEARCHMATE_MODE=fallback