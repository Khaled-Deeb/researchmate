# Copy this file to .env and fill in your values.

# Required only for future OpenAI-powered mode.
# The current fallback mode works without an API key.
OPENAI_API_KEY=

# Future LLM settings.
# This is only a placeholder. Check OpenAI docs before final API integration.
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Current mode:
# fallback = no API, rule-based extraction/search
# openai = future LLM-powered mode
RESEARCHMATE_MODE=fallback